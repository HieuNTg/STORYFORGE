{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "isolatedModules": true
  },
  "include": ["web/js/**/*.ts"],
  "exclude": ["node_modules", "dist", "web/js/__tests__/**", "web/js/types/**"]
}
