# StoryForge Production Environment Variables
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to source control.
#
# Usage: docker compose --env-file .env.production -f docker-compose.production.yml up -d

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password — use a strong random value (min 32 chars)
# Generate: openssl rand -base64 32
DB_PASSWORD=change_me_use_strong_random_password

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────

# Secret key for signing sessions / tokens (min 64 chars)
# Generate: openssl rand -base64 64
SECRET_KEY=change_me_use_strong_random_secret_key

# Comma-separated allowed CORS origins (no trailing slash)
# Example: https://storyforge.example.com,https://www.storyforge.example.com
ALLOWED_ORIGINS=https://storyforge.example.com

# ─────────────────────────────────────────────────────────────────────────────
# LLM / AI BACKEND
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI-compatible API key
# For OpenAI: sk-...
# For local (Ollama/LM Studio): set to any non-empty value
STORYFORGE_API_KEY=sk-your-api-key-here

# Base URL for the LLM API endpoint
# OpenAI:    https://api.openai.com/v1
# Ollama:    http://host.docker.internal:11434/v1
# LM Studio: http://host.docker.internal:1234/v1
STORYFORGE_BASE_URL=https://api.openai.com/v1

# Model to use for story generation
# OpenAI examples: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Ollama example:  llama3.2
STORYFORGE_MODEL=gpt-4o-mini

# Backend type: api | ollama | lmstudio
STORYFORGE_BACKEND=api

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
STORYFORGE_TEMPERATURE=0.8

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Enable quality gate (re-evaluates story quality before returning)
STORYFORGE_QUALITY_GATE=true

# Enable smart revision (auto-revises low-scoring sections)
STORYFORGE_SMART_REVISION=true

# Enable agent debate (multi-agent deliberation, slower but higher quality)
STORYFORGE_AGENT_DEBATE=false

# ─────────────────────────────────────────────────────────────────────────────
# NGINX / TLS
# ─────────────────────────────────────────────────────────────────────────────

# Public domain name — used in nginx server_name and SSL cert paths
# Must match the Let's Encrypt certificate domain
NGINX_SERVER_NAME=storyforge.example.com

# ─────────────────────────────────────────────────────────────────────────────
# HEALTH CHECK SCRIPT (scripts/health-check.sh)
# ─────────────────────────────────────────────────────────────────────────────

# Override these when running health-check.sh against a remote host
# APP_HOST=localhost
# APP_PORT=7860
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# REDIS_HOST=localhost
# REDIS_PORT=6379
