{
  "name": "storyforge-frontend",
  "version": "1.0.0",
  "description": "StoryForge AI-powered story generation platform — frontend build pipeline",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json",
    "build:css": "tailwindcss -i web/css/main.css -o web/css/main.built.css --minify",
    "build:vite": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write \"web/js/**/*.ts\"",
    "test:visual": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/alpinejs": "^3.13.0",
    "@types/d3-force": "^3.0.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.4.0",
    "vite": "^6.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "d3-force": "^3.0.0"
  }
}
